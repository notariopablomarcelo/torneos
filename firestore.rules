rules_version = '2';

service cloud.firestore {
	match /databases/{database}/documents {
		// Reglas conservadoras por defecto: solo lectura/escritura autenticada.
		// Cuando definamos el modelo de permisos (admin / fiscal / público),
		// refinamos por colección.
		match /{document=**} {
			allow read, write: if request.auth != null;
		}
	}
}
